---
import { CookingPot } from "lucide-react";
import { siFacebook, siInstagram, siYoutube, siX } from "simple-icons";
---

<footer class="p-6">
  <div
    class="mx-auto flex max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8"
  >
    <a href="#" class="flex gap-2">
      <CookingPot />
      <span class="text-primary text-[20px] font-semibold">Bistro</span>
    </a>

    <nav class="hidden md:block">
      <ul class="flex gap-6">
        <li>
          <a
            href="#about"
            class="text-sm hover:text-primary transition-colors duration-200"
            >About Us</a
          >
        </li>
        <li>
          <a
            href="#testimonials"
            class="text-sm hover:text-primary transition-colors duration-200"
            >Testimonials</a
          >
        </li>
        <li>
          <a
            href="#contact"
            class="text-sm hover:text-primary transition-colors duration-200"
            >Contact Us</a
          >
        </li>
        <li>
          <a
            href="#offers"
            class="text-sm hover:text-primary transition-colors duration-200"
            >Offers</a
          >
        </li>
      </ul>
    </nav>

    <div class="flex gap-4 items-center">
      <a href="#" class="hover:text-primary transition-colors duration-200"
        ><svg role="img" viewBox="0 0 24 24" class="size-5 fill-current">
          <path d={siFacebook.path}></path>
        </svg></a
      >
      <a href="#" class="hover:text-primary transition-colors duration-200"
        ><svg role="img" viewBox="0 0 24 24" class="size-5 fill-current">
          <path d={siInstagram.path}></path>
        </svg></a
      >
      <a href="#" class="hover:text-primary transition-colors duration-200"
        ><svg role="img" viewBox="0 0 24 24" class="size-5 fill-current">
          <path d={siX.path}></path>
        </svg></a
      >
      <a href="#" class="hover:text-primary transition-colors duration-200"
        ><svg role="img" viewBox="0 0 24 24" class="size-5 fill-current">
          <path d={siYoutube.path}></path>
        </svg></a
      >
    </div>
  </div>

  <div class="w-full border-t-2 my-8 border-muted"></div>

  <p class="text-muted-foreground text-center">
    ©2026 Bistro, recreated by Tomáš Greguš.
  </p>
</footer>
