---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
}

const {
  title = "Bistro – Fine Dining Experience",
  description = "Experience exceptional cuisine in the heart of the city.",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <slot />
  </body>
</html>
